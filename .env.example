# Smartsheet
SMARTSHEET_ACCESS_TOKEN=your-smartsheet-token

# FieldNation (OAuth2)
FN_CLIENT_ID=your-fn-client-id
FN_CLIENT_SECRET=your-fn-client-secret
FN_BASE_URL=https://api.fieldnation.com
