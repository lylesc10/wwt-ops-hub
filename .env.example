# ── Azure Database for PostgreSQL ────────────────────────────
DATABASE_URL=postgresql://opshub_user:changeme@your-server.postgres.database.azure.com:5432/opshub?sslmode=require

# ── Custom JWT auth ───────────────────────────────────────────
JWT_SECRET=change-me-at-least-64-chars-random-secret
JWT_REFRESH_SECRET=another-random-secret-for-refresh-tokens
JWT_ISSUER=wwt-ops-hub
JWT_AUDIENCE=wwt-ops-hub-api

# ── Data API Builder (internal URL, not public) ────────────────
# Set to the internal DAB Container App URL in Azure
DAB_INTERNAL_URL=http://localhost:5000

# ── Frontend base URLs (baked into the SPA at build time) ─────
VITE_API_BASE=http://localhost:8080
VITE_APP_ENV=dev
VITE_FN_MOCK=true

# ── FieldNation (OAuth2) ──────────────────────────────────────
FN_CLIENT_ID=your-fn-client-id
FN_CLIENT_SECRET=your-fn-client-secret
FN_BASE_URL=https://api.fieldnation.com
FN_USERNAME=
FN_PASSWORD=

# ── Smartsheet ────────────────────────────────────────────────
SMARTSHEET_ACCESS_TOKEN=your-smartsheet-token

# ── Twilio (SMS) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Anthropic (AI) ────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in dev)
ALLOWED_ORIGINS=

